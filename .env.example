# =====================================================================
#  Yakal Portal — environment template.  Copy to .env and fill in.
#  .env is git-ignored; this .example is committed as documentation.
#
#  Only VITE_ vars reach the browser (and must be non-secret).
#  Everything else is server-side and belongs in Supabase secrets,
#  never in the repo or the client bundle.
# =====================================================================

# ---- Public frontend config (safe in the browser) -------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ---- Database (for `npm run migrate` only) --------------------------
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# =====================================================================
#  SERVER-SIDE SECRETS — set in Supabase:  supabase secrets set NAME=value
# =====================================================================

# ---- Resend (deadline-reminder email) ------------------------------
RESEND_API_KEY=re_YOUR_RESEND_KEY
REMINDER_FROM=Yakal <reminders@your-domain>

# ---- Deadline-reminders Edge Function guard ------------------------
REMINDER_SECRET=A-LONG-RANDOM-STRING

# ---- Zoom (server-to-server OAuth; meeting:write scope) ------------
ZOOM_ACCOUNT_ID=YOUR-ZOOM-ACCOUNT-ID
ZOOM_CLIENT_ID=YOUR-ZOOM-CLIENT-ID
ZOOM_CLIENT_SECRET=YOUR-ZOOM-CLIENT-SECRET

# ---- Supabase service role (admin key; bypasses RLS — keep secret) --
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
